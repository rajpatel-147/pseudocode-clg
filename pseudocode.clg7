          p = (p+2)+q
          JUMP OUT TO THE LOOP
          END IF
          PRINT p+q+r
         */
        int p1 = 7, q1 = 10, r1 = 9;
        for (r1 = 3; r1 <= 4; r1++) {
            p1 = q1;
            if ((q1 - p1 + r1) < (r1 + q1)) {
                continue;
            } else {
                p1 = (5 + 6) ^ r1;
                break; }
        }
        System.out.println(p1 + q1);
