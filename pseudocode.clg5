        for (int r4 = 0; r4 < 3; r4++) {
            for (int c4 = 0; c4 < 3; c4++) {
                y4[r4][c4] = sc.nextInt();
            }
        }
        for (int r4 = 0; r4 < 3; r4++) {
            for (int c4 = 0; c4 < 3; c4++) {
                z4[r4][c4] = y4[r4][c4] + x4[r4][c4];
            }
        }
        System.out.println("Result matrix:");
        for (int r4 = 0; r4 < 3; r4++) {
            for (int c4 = 0; c4 < 3; c4++) {
                System.out.print(z4[r4][c4] + " ");
