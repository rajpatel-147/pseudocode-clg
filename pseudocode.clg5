        System.out.println("COUNTING OF ODD AND EVEN");
        int[][] x3 = new int[3][3];
        int even = 0;
        int odd = 0;
        for (int r3 = 0; r3 < 3; r3++) {
            for (int c3 = 0; c3 < 3; c3++) {
                x3[r3][c3] = sc.nextInt();
            }}
        for (int r3 = 0; r3 < 3; r3++) {
            for (int c3 = 0; c3 < 3; c3++) {
                if (x3[r3][c3] % 2 == 0) {
                    even++;
                } else {
                    odd++;
                }
            }}
        System.out.println("Even numbers: " + even);
        System.out.println("Odd numbers: " + odd);


        // ADDITION OF TWO MATRIX
