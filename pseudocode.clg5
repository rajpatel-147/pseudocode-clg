        System.out.println("SUM OF TWO 2D ARRAY IN NEW ARRAY IN NEW 2D ARRAY");

        int[][] x4 = new int[3][3];
        int[][] y4 = new int[3][3];
        int[][] z4 = new int[3][3];

        System.out.println("Enter elements of first matrix:");
        for (int r4 = 0; r4 < 3; r4++) {
            for (int c4 = 0; c4 < 3; c4++) {
                x4[r4][c4] = sc.nextInt();
            }
